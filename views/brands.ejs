<!DOCTYPE html>
<html lang="en">
<%- include('htmlHead')  %>

<body>
  <%- include('nav')  %>
  <h1>Brands</h1>
  <div class="type-container">
    <% for(const brand of brands) {%>
    <div class="type" data-id="<%= brand.id  %>">
      <button class="editBtn">
        <img src="/images/pencil.png">
      </button>
      <button class="deleteBtn" onclick="handleDelete(<%= brand.id %>)">
        <img src="/images/trash.png">
      </button>
      <p><%= brand.name %></p>
    </div>
    <% } %>
    <div class="create">
      <button id="create">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <title>plus-box-outline</title>
          <path d="M19,19V5H5V19H19M19,3A2,2 0 0,1 21,5V19A2,2 0 0,1 19,21H5A2,2 0 0,1 3,19V5C3,3.89 3.9,3 5,3H19M11,7H13V11H17V13H13V17H11V13H7V11H11V7Z" />
        </svg>
      </button>
    </div>

  </div>

</body>

<script>
  //Brand selection
  const brandElements = document.querySelectorAll('.type');
  brandElements.forEach(el => el.addEventListener('click', handleBrandClick));

  function handleBrandClick(e) {
    const brandID = e.currentTarget.dataset.id
    if (e.target.localName === 'button' || e.target.localName === 'img') return;
    location.href = '/inventory/brands/' + brandID;
  }

  // Body type create
  const createBtn = document.getElementById('create');

  createBtn.addEventListener('click', handleCreate);

  function handleCreate(e) {
    const parentNode = e.currentTarget.parentNode;
    e.currentTarget.remove();

    const form = document.createElement('form');
    const input = document.createElement('input');
    const btnContainer = document.createElement('div');
    const submitBtn = document.createElement('button');
    const cancelBtn = document.createElement('button');

    form.action = 'brands/create/';
    form.method = 'POST';
    input.id = 'name';
    input.name = 'name';
    input.type = 'text';
    submitBtn.textContent = 'Submit';
    cancelBtn.textContent = 'Cancel';
    cancelBtn.type = 'button';
    cancelBtn.onclick = () => cancelCreate(parentNode, createBtn);

    btnContainer.appendChild(submitBtn);
    btnContainer.appendChild(cancelBtn);

    form.appendChild(input);
    form.appendChild(btnContainer);

    parentNode.appendChild(form);
  }

  function cancelCreate(parentNode, createBtn) {
    parentNode.innerHTML = '';
    parentNode.appendChild(createBtn);
  }

  //Brand edit 
  const editBtns = [...document.querySelectorAll('.editBtn')];
  editBtns.forEach(el => el.addEventListener('click', handleEditClick));

  let previousContainer = null;

  function handleEditClick(e) {
    const parentNode = e.currentTarget.parentNode
    parentNode.removeEventListener('click', handleBrandClick);

    if (previousContainer) {
      previousContainer.ref.innerHTML = previousContainer.innerHTML;
      previousContainer.ref.addEventListener('click', handleBrandClick);
      const editBtn = previousContainer.ref.querySelector('.editBtn');
      editBtn.addEventListener('click', handleEditClick);
    }

    previousContainer = {
      ref: parentNode,
      innerHTML: parentNode.innerHTML
    };

    const currentValue = parentNode.childNodes[5].textContent;
    const brandId = parentNode.dataset.id;

    parentNode.innerHTML = '';
    const form = document.createElement('form');
    const input = document.createElement('input');
    const btnContainer = document.createElement('div');
    const submitBtn = document.createElement('button');
    const cancelBtn = document.createElement('button');

    form.action = 'brands/update/' + brandId;
    form.method = 'POST';
    input.id = 'brandName';
    input.name = 'brandName';
    input.type = 'text';
    input.value = currentValue;
    submitBtn.textContent = 'Submit';
    cancelBtn.textContent = 'Cancel';
    cancelBtn.type = 'button';
    cancelBtn.onclick = handleCancel;

    btnContainer.appendChild(submitBtn);
    btnContainer.appendChild(cancelBtn);

    form.appendChild(input);
    form.appendChild(btnContainer);


    parentNode.appendChild(form);
  }

  function handleCancel() {
    previousContainer.ref.innerHTML = previousContainer.innerHTML;
    previousContainer.ref.addEventListener('click', handleBrandClick);
    const editBtn = previousContainer.ref.querySelector('.editBtn');
    editBtn.addEventListener('click', handleEditClick);
  }

  // Body type delete
  async function handleDelete(brandId) {
    try {
      let response = await fetch('brands/delete/' + brandId, {
        method: 'DELETE'
      })
      result = (await response.json()).response;

      if (result) {
        const container = document.querySelector(`[data-id="${brandId}"]`);
        container.remove();
      } else {
        alert('This brand contains elements inside, delete all its elements before deleting the brand!')
      }
    } catch (error) {
      console.log(error);
    }
  }
</script>


</html>